{
	"name": "n8n-nodes-advanced-webhook-response",
	"version": "0.1.0",
	"description": "Advanced Respond to Webhook node for n8n with HTML iframe wrapping, configurable sandbox/device permissions, CORS helpers, security headers, and cookie management",
	"license": "MIT",
	"homepage": "https://github.com/virtualarkansas/n8n-nodes-advanced-webhook-response",
	"keywords": [
		"n8n-community-node-package"
	],
	"author": {
		"name": "Kyle Yancey"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/virtualarkansas/n8n-nodes-advanced-webhook-response.git"
	},
	"main": "dist/nodes/AdvancedRespondToWebhook/AdvancedRespondToWebhook.node.js",
	"scripts": {
		"build": "tsc && copyfiles \"nodes/**/*.svg\" dist/",
		"dev": "tsc --watch",
		"lint": "eslint nodes/ --ext .ts",
		"prepublishOnly": "npm run build"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"nodes": [
			"dist/nodes/AdvancedRespondToWebhook/AdvancedRespondToWebhook.node.js"
		],
		"credentials": []
	},
	"devDependencies": {
		"@types/jsonwebtoken": "^9.0.0",
		"copyfiles": "^2.4.1",
		"n8n-workflow": "^2.11.0",
		"typescript": "^5.5.0"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"jsonwebtoken": "^9.0.0"
	}
}
